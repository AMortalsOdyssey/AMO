PG_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/amo_canon
PG_SCHEMA=amo
PUBLIC_APP_URL=http://localhost:3000

AUTH_ENABLED=true
AUTH_REQUIRE_VERIFIED_EMAIL=true
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_COOKIE_NAME=amo_session
AUTH_SESSION_TTL_DAYS=30
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_COOKIE_DOMAIN=

IDENTITY_PLATFORM_PROJECT_ID=your-gcp-project-id
IDENTITY_PLATFORM_SERVICE_ACCOUNT_PATH=/absolute/path/to/identity-platform-admin.json
# IDENTITY_PLATFORM_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
